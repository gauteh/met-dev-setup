[include]
  path = ".gitconfig-met"
[includeIf "gitdir:dev/"]
  path = ".gitconfig-home"
[user]
  signingkey = A0749023
[push]
  default = simple
[alias]
  co = checkout
  ci = commit
  cp = cherry-pick
  s  = status
  clog = log --date=short --pretty=format:\"%Cred%ad %Cblue%h %Cgreen%an %Creset%s%C(yellow)%d\"
  wlog = log --date=short --pretty=format:\"%ad %h %an %s%d\"
  slog = log --date=short --pretty=format:\"%C(124)%ad %C(24)%h %C(34)%an %C(252)%s%C(178)%d\"
  llog = log --date=short --format=\"%C(94)--------------------------------------------------------------------------------%n%C(24)%h %C(124)%ad %C(34)%an %C(22)<%ae>%C(130)%d%n%C(178) %s%n%n%B(1)\"
  post = !sh -c 'git format-patch --stdout $1 | ix' -
  pullify = config --add remote.origin.fetch '+refs/pull/*/head:refs/remotes/origin/pull/*'
  amen  = commit --amend --no-edit
  ldiff = latexdiff -b --tectonic
  dc    = describe  --tags --always --abbrev=8
  fp    = format-patch -k -M -N
  b     = branch -v

  # the acronym stands for "subtree add"
  sba = "!f() { git subtree add --prefix $2 $1 master; }; f"
  # the acronym stands for "subtree update"
  sbu = "!f() { git subtree pull --prefix $2 $1 master; }; f"

  # folder stuff
  root = rev-parse --show-toplevel
  pwd  = rev-parse --show-prefix
  exec = "!exec "
  pushfl = push --force-with-lease

[color]
  branch = auto
  diff = auto
  grep = auto
  interactive = auto
  showbranch = auto
  status = auto
  ui = auto
[color "branch"]
  current = green
  local = yellow
  remote = red
[color "diff"]
  meta = yellow
[color "grep"]
  match = green
[color "status"]
  changed = yellow
[merge]
  tool = fugitive
[diff]
  renames = true
  tool = fugitive
[difftool]
  trustExitCode = true
  prompt = false
[mergetool]
  trustExitCode = true
  prompt = false
[mergetool "fugitive"]
  cmd = nvim -f -c \"Gvdiffsplit!\" \"$MERGED\"
[difftool "fugitive"]
  cmd = nvim -f -c \"Gvdiffsplit!\" \"$MERGED\"

[github]
  user = gauteh
  gist-oauth-token = 83b66c3f7d7ba911172795c5f17233e3b0fcde65

[core]
  excludesfile = ~/.gitignore_global
[sendemail]
  smtpserver = /usr/bin/msmtp
  confirm = always
  chainreplyto = false
[status]
  submoduleSummary = true

[pull]
  ff = only
[init]
  defaultBranch = main
[credential]
	helper = store
